# ============================================================
# Job Pipeline Orchestrator Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your keys.

# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here
NOTION_TOKEN=your_notion_token_here

# Optional — enables LinkedIn scraping via Apify
APIFY_TOKEN=your_apify_token_here

# Optional — enables contact enrichment via Vibe Prospecting
VIBE_PROSPECTING_API_KEY=your_vibe_prospecting_api_key_here

# Notion database IDs (auto-populated from pipeline setup)
NOTION_JOBS_DB=5135bb9f-2ad7-4400-b42a-b07d35a37d43
NOTION_CONTACTS_DB=7e736104-656e-470c-b301-7bcd3c8dee82

# Resume file path (PDF or TXT)
RESUME_PATH=resume.pdf

# Defaults
DEFAULT_LOCATION=Denver, CO
MIN_FIT_SCORE=7
MIN_RELEVANCE_SCORE=7
MAX_JOBS=10

# Your Reslink video URL for outreach messages
RESLINK_URL=[Reslink URL]
